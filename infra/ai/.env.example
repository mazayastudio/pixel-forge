# PixelForge API / AI worker environment
# Copy to .env on homelab backend and MAZAYA-STUDIO worker host

# --- App backend ---
API_PORT=3000
DATABASE_URL=postgres://pixelforge:changeme@localhost:5432/pixelforge
JWT_SECRET=change-me-in-production

# --- MAZAYA-STUDIO AI (Tailscale) ---
OLLAMA_BASE_URL=http://100.89.170.66:11434
OLLAMA_MODEL_PRIMARY=qwen2.5:7b-instruct
OLLAMA_MODEL_FALLBACK=qwen2.5:3b
OLLAMA_MODEL_HEAVY=qwen3:8b

COMFYUI_BASE_URL=http://100.89.170.66:8188
COMFYUI_CHECKPOINT=pixel_dream_v1.0.safetensors

# Health check interval (seconds)
AI_HEALTH_CHECK_INTERVAL=30

# --- Generation defaults ---
GEN_NATIVE_SIZE=512
GEN_DEFAULT_DENOISE_IMG2IMG=0.45
GEN_MAX_COLORS=32

# --- Fast quantize (client-side, no AI) ---
FAST_QUANTIZE_ENABLED=true
